# LLM for the classify/extract/match nodes, served via NVIDIA NIM
# (build.nvidia.com) through the langchain-nvidia-ai-endpoints package.
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_API_KEY=

# Gmail OAuth (see the /gmail-setup skill for how to obtain these)
GMAIL_CLIENT_SECRETS_PATH=.secrets/credentials.json
GMAIL_TOKEN_PATH=.secrets/token.json

# SQLite database file
DB_PATH=applysync.db

# How often the scheduler polls Gmail, in minutes
SYNC_INTERVAL_MINUTES=20

# Observability (phase 2, leave blank until M5)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# LLM provider for the classify/extract/match nodes.
# Uses langchain's provider-agnostic init_chat_model, so any supported
# provider works as long as its API key env var is set below.
LLM_MODEL=anthropic:claude-sonnet-5
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Gmail OAuth (see the /gmail-setup skill for how to obtain these)
GMAIL_CLIENT_SECRETS_PATH=.secrets/credentials.json
GMAIL_TOKEN_PATH=.secrets/token.json

# SQLite database file
DB_PATH=job_tracker.db

# How often the scheduler polls Gmail, in minutes
SYNC_INTERVAL_MINUTES=20

# Observability (phase 2, leave blank until M5)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

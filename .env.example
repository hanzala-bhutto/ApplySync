# LLM for the classify/extract/match nodes, served via NVIDIA NIM
# (build.nvidia.com) through the langchain-nvidia-ai-endpoints package.
LLM_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_API_KEY=

# Gmail OAuth (see the /gmail-setup skill for how to obtain these)
GMAIL_CLIENT_SECRETS_PATH=.secrets/credentials.json
GMAIL_TOKEN_PATH=.secrets/token.json

# SQLite database file
DB_PATH=applysync.db

# How often the scheduler polls Gmail, in minutes
SYNC_INTERVAL_MINUTES=20

# Self-hosted SearXNG instance for web-research features (start it with
# `docker compose up -d` in searxng/). Local and keyless, no external account.
SEARXNG_URL=http://localhost:8888

# Observability: self-hosted Langfuse (M5 step 2), NOT LangSmith - a hosted
# SaaS would ship email bodies off-machine, contradicting the local-first
# design. Start the stack with `docker compose up -d` in langfuse/, sign up at
# http://localhost:3000, create a project, and paste its keys here. Tracing is
# off (no-op) whenever these are unset - not required to run the pipeline.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

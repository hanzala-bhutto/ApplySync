# Copy to langfuse/.env (gitignored) and fill in real values before `docker
# compose up -d`. Generate each with: openssl rand -hex 32 (or -hex 16 for the
# shorter ones marked below). These are local-only secrets for a self-hosted,
# single-user stack - not shared with any external service.
SALT=
ENCRYPTION_KEY=
NEXTAUTH_SECRET=
POSTGRES_PASSWORD=
CLICKHOUSE_PASSWORD=
# openssl rand -hex 16
MINIO_ROOT_PASSWORD=
# openssl rand -hex 16
REDIS_AUTH=

#!/bin/sh
# Local eval gate: block a push that changes prompt/model/pipeline behavior
# unless the eval harness still passes its thresholds.
#
# Why local, not in cloud CI: the gold dataset holds real email bodies (PII,
# gitignored) and the eval hits the live rate-limited NVIDIA model. Neither can
# go to a GitHub runner, so the gate lives here. Only the pass/fail decision
# leaves this machine (via the push); no data does.
#
# Activate with: sh scripts/install-hooks.sh
# Bypass one push (e.g. a docs-only change the path filter misclassifies, or a
# machine without the gold data / model key): git push --no-verify
#
# Requires the project venv active (so `python` resolves to one with applysync
# installed and the eval dependencies available).

z40=0000000000000000000000000000000000000000
changed=""

while read -r local_ref local_sha remote_ref remote_sha; do
	[ "$local_sha" = "$z40" ] && continue   # branch deletion, nothing to check
	if [ "$remote_sha" = "$z40" ]; then
		# New branch on the remote: diff against origin/main's merge-base.
		base=$(git merge-base origin/main "$local_sha" 2>/dev/null || echo "")
		[ -z "$base" ] && base=$(git rev-list --max-parents=0 "$local_sha" | tail -1)
		range="$base..$local_sha"
	else
		range="$remote_sha..$local_sha"
	fi
	changed="$changed $(git diff --name-only "$range")"
done

# Files whose change can move eval numbers: prompts/nodes, the LLM output
# schema, the keyword/source config, model settings, and the research agents.
if ! printf '%s\n' "$changed" | grep -qE 'pipeline/(nodes|state)\.py|config/sources\.yaml|applysync/config\.py|applysync/research/'; then
	echo "pre-push: no prompt/model-affecting change, skipping eval gate."
	exit 0
fi

echo "pre-push: prompt/model-affecting change detected, running eval gate (real model, may take a few minutes)..."
if ! command -v python >/dev/null 2>&1; then
	echo "pre-push: python not on PATH (venv not active?). Aborting push; bypass with --no-verify if intended." >&2
	exit 1
fi

if python eval/run_eval.py --strict; then
	echo "pre-push: eval gate PASSED."
	exit 0
fi

echo "pre-push: eval gate FAILED - a prompt/model change regressed below threshold. Push aborted." >&2
echo "         Investigate, or bypass with: git push --no-verify" >&2
exit 1
